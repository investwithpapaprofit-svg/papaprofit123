rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {

      function isAuthenticated() {
        return request.auth != null;
      }

      function isOwner(uid) {
        return isAuthenticated() && request.auth.uid == uid;
      }

      function isAdmin() {
        return isAuthenticated() &&
               request.auth.token.admin == true;
      }

      function isSafeProfileWrite() {
        let incoming = request.resource.data.get('profile', {});
        let existing = resource == null
          ? {}
          : resource.data.get('profile', {});

        let keepsPremium =
          incoming.get('isPremium', false) ==
          existing.get('isPremium', false);

        let keepsRole =
          incoming.get('role', 'user') ==
          existing.get('role', 'user');

        return keepsPremium && keepsRole;
      }

      allow read:
        if isOwner(userId) || isAdmin();

      allow create:
        if isOwner(userId) &&
           isSafeProfileWrite();

      allow update:
        if (
          isOwner(userId) &&
          isSafeProfileWrite()
        ) || isAdmin();

      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
